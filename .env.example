# Slack credentials (required)
SAI_SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SAI_SLACK_APP_TOKEN=xapp-your-app-token-here

# LLM endpoint (LM Studio / OpenAI-compatible API)
SAI_LLM_BASE_URL=http://localhost:1234/v1
SAI_LLM_API_KEY=lm-studio
SAI_LLM_MODEL=openai/gpt-oss-20b
SAI_LLM_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Optional overrides
SAI_LOG_LEVEL=INFO
SAI_DB_PATH=./data/sai.db
SAI_CHROMA_PATH=./data/chroma
